# .env.defaults — version-controlled, NON-SECRET project environment.
#
# Loaded into every Claude session (CLI and Claude Code on the web) by the
# SessionStart hook scripts/load_project_env.sh, which appends each line to
# $CLAUDE_ENV_FILE so the values are available to all subsequent Bash commands.
#
# ONLY non-secret config belongs here — this file IS committed to git.
# Secrets (ALLOYDB_OMNI_PASSWORD, *_API_KEY, *_OAUTH_TOKEN, NEON_DATABASE_URL)
# MUST NOT appear here; they live in the cloud-env UI / macOS Keychain / .dev.vars
# per docs/operator-runbooks/cloud-env-vars-contract.md.
#
# ANTHROPIC_API_KEY is FORBIDDEN anywhere (OAuth-only invariant, src/oauth/token.ts).
#
# Format: KEY=value, one per line, no quotes, no `export` (the hook adds it).
# Lines starting with # and blank lines are ignored. A value already present in
# the environment is NOT overwritten (the hook skips it), so a session/cloud-UI
# override always wins.

# Cloudflare Worker routing (non-secret; account id + worker name only).
CLOUDFLARE_ACCOUNT_ID=e6294e3ea89f8207af387d459824aaae
CLOUDFLARE_WORKER_NAME=ke-cloud-agent

# Identity flag: 0 at the Worker, flipped to 1 inside the Sandbox. Default 0.
IS_SANDBOX=0

# KE_* path/mode overrides consumed by scripts/ (all have code defaults; set here
# for explicitness so CLI and web resolve identically).
KE_VENDOR_DIR=vendor
KE_SERVERS_DIR=.claude/servers
KE_PLANNER_MODE=default
