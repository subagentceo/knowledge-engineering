{
  "name": "calendar-frontend",
  "main": "src/worker.ts",
  "compatibility_date": "2025-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "e6294e3ea89f8207af387d459824aaae",
  "routes": [
    {
      "pattern": "calendar.subagentknowledge.com",
      "zone_id": "3f820e0424fd375d5b6f86acaad0d5d7",
      "custom_domain": true
    }
  ],
  "vars": {
    "SITE_NAME": "calendar",
    "COWORKERS_HOST": "coworkers.subagentknowledge.com"
  },
  "durable_objects": {
    "bindings": [{ "name": "MCP_OBJECT", "class_name": "CalendarMcp" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["CalendarMcp"] }]
}
