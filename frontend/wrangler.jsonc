// frontend/wrangler.jsonc
//
// Phase 13.B+ (O7). Public-facing single-page Worker for subagentknowledge.com.
// Separate from infra/cloudflare/ke-cloud-agent (the agent runtime) so
// the public surface inherits ZERO Claude secrets.
//
// Citations:
//   - vendor/cloudflare/developers.cloudflare.com/workers/static-assets/llms.txt
//   - vendor/anthropics/neon.com/guides/cloudflare-sandbox-neon-branching.md
//     (architectural separation rationale)
//
// Deploy:
//   cd frontend && npm install && npm run build && wrangler deploy
//
// Custom domain: subagentknowledge.com (+ www) is bound via the
// routes[].custom_domain directive. Wrangler handles DNS + cert
// provisioning on deploy when the API token has Zone:Edit permission
// for the zone.
//
// NOTE: the deployed Worker script keeps the legacy name
// "outcomesdk-frontend" — renaming it would create a NEW Worker and
// detach the custom domains. HTTPS + canonical-host enforcement lives
// in src/worker.ts because the deploy token cannot edit zone settings.
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "outcomesdk-frontend",
  "compatibility_date": "2026-01-01",
  "compatibility_flags": ["nodejs_compat"],

  // Workers Static Assets binding. The build pipeline (vite + the
  // build-vendor-manifest script) emits everything into ./dist; the
  // Worker serves it at every path that doesn't match the runtime
  // routes below.
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "single-page-application"
  },

  "main": "src/worker.ts",

  "routes": [
    {
      "pattern": "subagentknowledge.com",
      "custom_domain": true
    },
    {
      "pattern": "www.subagentknowledge.com",
      "custom_domain": true
    }
  ],

  "vars": {
    "SITE_NAME": "subagentknowledge"
  }
}
