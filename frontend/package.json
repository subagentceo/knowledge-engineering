{
  "name": "@subagentceo/outcomesdk-frontend",
  "version": "0.2.0",
  "private": true,
  "description": "outcomesdk.com — single-page Cloudflare Worker site rendering vendor/ markdown via @chenglou/pretext (sane accordion + monospace ASCII). Phase 13.B+ (O7).",
  "type": "module",
  "scripts": {
    "build:manifest": "tsx scripts/build-vendor-manifest.ts",
    "build": "npm run build:manifest && vite build",
    "dev": "vite dev",
    "deploy:dry-run": "npm run build && wrangler deploy --dry-run",
    "deploy": "npm run build && wrangler deploy",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.7",
    "dompurify": "^3.2.0",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "@types/dompurify": "^3.2.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.7.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  },
  "overrides": {
    "ws": ">=8.20.1"
  }
}
