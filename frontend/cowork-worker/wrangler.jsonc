// frontend/cowork-worker/wrangler.jsonc
//
// CF Worker: cowork.subagentknowledge.com
// McpAgent-backed worker — serves app shell at / and MCP server at /mcp.
// Durable Object required for McpAgent session state (SQLite-backed).
//
// @cite github.com/cloudflare/agents                (McpAgent + DO pattern)
// @cite plugins/mcp-server-dev/references/deploy-cloudflare-workers.md
// @cite cowork/coworkers/manifest.json              (7 coworker definitions)
//
// Deploy:
//   cd frontend && npx wrangler deploy --config cowork-worker/wrangler.jsonc
{
  "name": "cowork-frontend",
  "main": "src/worker.ts",
  "compatibility_date": "2026-01-01",
  "compatibility_flags": ["nodejs_compat"],

  "durable_objects": {
    "bindings": [
      { "name": "MCP_OBJECT", "class_name": "CoworkMcp" }
    ]
  },

  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["CoworkMcp"] }
  ],

  "routes": [
    {
      "pattern": "cowork.subagentknowledge.com",
      "custom_domain": true
    }
  ],

  "vars": {
    "SITE_NAME": "cowork",
    "COWORKERS_HOST": "coworkers.subagentknowledge.com"
  }
}
