{
  "//": "O-CICD1 enabler. Deploy to the file-based managed-settings path (admin precedence, applies to ALL users/sessions):",
  "//macos": "/Library/Application Support/ClaudeCode/managed-settings.json",
  "//linux": "/etc/claude-code/managed-settings.json",
  "//windows": "C:\\Program Files\\ClaudeCode\\managed-settings.json",
  "//why": "GHES has no GitHub MCP support (github-enterprise-server.md), and Claude-Code-on-the-web GitHub MCP is scoped to one repo. These keys let me act across all 10 subagentmcp orgs via gh CLI + local multi-repo checkouts without per-call prompts.",

  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(gh *)",
      "Bash(scripts/ops/pause-claude-cicd.sh*)",
      "Bash(git clone *)",
      "Edit(.github/workflows/**)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.github.com)"
    ],
    "deny": [],
    "additionalDirectories": [
      "../managedsubagents/",
      "../opencoworkers-ai/",
      "../opensubagents/",
      "../opensubagents-ai/",
      "../outcomesdk/",
      "../subagentapps/",
      "../subagentceo/",
      "../subagentcowork/",
      "../subagentknowledge/",
      "../subagentplugins/"
    ]
  },

  "enableAllProjectMcpServers": true,
  "extraKnownMarketplaces": {
    "subagentmcp-internal": {
      "source": { "source": "git", "url": "https://github.com/subagentceo/knowledge-engineering.git" }
    }
  }
}
