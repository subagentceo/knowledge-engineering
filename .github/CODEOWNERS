# polyrepo-pattern ADRs require explicit operator approval. Claude
# cannot self-merge these via automerge train.

/third_party/                            @alex-jadecli
/.gitmodules                             @alex-jadecli
/docs/decisions/*polyrepo*               @alex-jadecli
/docs/decisions/*third-party*            @alex-jadecli
/.github/CODEOWNERS                      @alex-jadecli
/.github/workflows/third-party-guard.yml @alex-jadecli
