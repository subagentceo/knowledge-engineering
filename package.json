{
  "name": "@subagentceo/knowledge-engineering",
  "version": "0.5.0",
  "description": "Four-lane knowledge bridge (anthropic.com/engineering, claude.com/blog, support.claude.com, llms.txt namespaces) over MCP SDK v2 to a Claude Agent SDK orchestrator with mode-aware Planner and OAuth-only billing.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ke-bridge-mcp": "dist/mcp/bridge-server.js",
    "ke-npm-registry-mcp": "dist/mcp/npm-registry/server.js",
    "ke-ext-tasks-mcp": "dist/mcp/ext-tasks/index.js",
    "ke-a2a-server": "dist/a2a/server.js",
    "ke-agent": "dist/agent/run.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/agent/run.ts",
    "mcp:bridge": "tsx src/mcp/bridge-server.ts",
    "mcp:npm-registry": "tsx src/mcp/npm-registry/server.ts",
    "mcp:ext-tasks": "tsx src/mcp/ext-tasks/index.ts",
    "mcp:hono": "tsx src/mcp-hono/server.ts",
    "a2a:server": "tsx src/a2a/server.ts",
    "rc": "claude remote-control --capacity 32 --spawn worktree",
    "rc:healer": "claude remote-control --capacity 4 --spawn worktree --name pr-healer",
    "example:prompt-caching": "tsx src/examples/prompt-caching.ts",
    "example:tool-caching": "tsx src/examples/tool-caching.ts",
    "example:citations": "tsx src/examples/citations.ts",
    "example:programmatic-tool-loop": "tsx src/examples/programmatic-tool-loop.ts",
    "example:deep-links": "tsx src/examples/deep-links.ts",
    "verify:planner": "tsx scripts/verify-planner.ts",
    "verify:citations": "tsx scripts/lib/citation-guard.ts",
    "verify:gates": "tsx scripts/validate-phase-gates.ts",
    "verify:libs": "tsx scripts/lib/run-tests.ts",
    "verify:coverage": "c8 tsx scripts/lib/run-tests.ts && tsx scripts/verify-coverage.ts",
    "verify:tdd": "tsx scripts/verify-tdd-stage.ts",
    "preflight": "tsx scripts/preflight-pr.ts",
    "osv:autofix": "tsx scripts/osv-autofix.ts",
    "verify:freshness": "tsx scripts/verify-freshness.ts",
    "build:plugin-cache": "tsx scripts/build-plugin-cache.ts",
    "verify:plugin-cache": "npm run build:plugin-cache && tsx scripts/verify-plugin-cache.ts",
    "harvest:admonitions": "tsx scripts/harvest-admonitions.ts",
    "verify:admonitions": "tsx scripts/harvest-admonitions.ts --dry-run",
    "verify:mcp": "tsx scripts/verify.ts && npm run verify:planner",
    "verify:tf": "terraform -chdir=infra/terraform init -backend=false -input=false && terraform -chdir=infra/terraform validate && terraform -chdir=infra/terraform plan -lock=false -input=false",
    "verify:env": "tsx infra/cloudflare/src/env-sanitize.test.ts && tsx infra/cloudflare/src/fm-relay.test.ts",
    "verify:project": "tsx scripts/verify-project.ts",
    "verify:security-posture": "tsx scripts/verify-security-posture.ts",
    "verify:secrets": "tsx scripts/verify-secrets-parity.ts",
    "verify:cube": "tsx scripts/lib/cube-guard.ts",
    "verify": "npm run verify:plugin-cache && npm run verify:admonitions && npm run verify:mcp && npm run verify:tf && npm run verify:citations && npm run verify:cube && npm run verify:dw && npm run verify:gates && npm run verify:libs && npm run verify:coverage && npm run verify:tdd && npm run verify:freshness && npm run verify:project && npm run verify:security-posture && npm run verify:env",
    "deploy:agent": "cd infra/cloudflare && npm run deploy",
    "deploy:frontend": "cd frontend && npm run deploy",
    "deploy:all": "npm run deploy:agent && npm run deploy:frontend",
    "sandbox:dev": "cd infra/cloudflare && npm run dev",
    "install:plugins": "tsx scripts/install-plugins.ts",
    "batch:submit": "tsx src/agent/batch-submit.ts",
    "batch:collect": "tsx src/agent/batch-collect.ts",
    "setup:project": "tsx scripts/setup-github-project.ts",
    "setup:branch-protection": "tsx scripts/setup-branch-protection.ts",
    "crawl:vendors": "tsx scripts/crawl-vendors.ts",
    "crawl:vendor": "tsx scripts/crawl-vendors.ts --vendor",
    "crawl:anduril-www": "tsx scripts/crawl-anduril-www.ts",
    "crawl:audit": "tsx scripts/crawl-vendor-audit.ts",
    "crawl:github": "tsx scripts/crawl-github.ts",
    "crawl:github:org": "tsx scripts/crawl-github.ts --org",
    "crawl:github:repo": "tsx scripts/crawl-github.ts --org $npm_config_org --repo",
    "crawl:registries": "tsx scripts/crawl-registries.ts",
    "crawl:npm": "tsx scripts/crawl-registries.ts npm",
    "crawl:pypi": "tsx scripts/crawl-registries.ts pypi",
    "crawl:crates": "tsx scripts/crawl-registries.ts crates",
    "crawl:all": "npm run crawl:vendors && npm run crawl:github && npm run crawl:registries",
    "gen:servers": "tsx scripts/generate-server-tree.ts",
    "gen:pr-queue": "tsx scripts/gen-pr-queue.ts",
    "emit:view": "tsx src/agent/team/emit-view.ts",
    "emit:view:watch": "tsx src/agent/team/emit-view.ts --watch",
    "app:orchestrator": "swift run --package-path apps/agent-orchestrator",
    "discover:sources": "tsx scripts/discover-sources.ts",
    "grade": "tsx scripts/grade-phase.ts",
    "context:budget": "tsx scripts/context-budget.ts",
    "goals": "tsx scripts/check-goals.ts",
    "docs:dev": "mintlify dev",
    "lint": "tsc --noEmit",
    "ke-verifier:setup": "tsx scripts/setup-coworker-verifier.ts",
    "ingest:kg": "tsx scripts/ingest-vendor-pages.ts",
    "verify:kg": "SKIP_KG_VERIFY=1 tsx scripts/verify-kg.ts",
    "ingest:citations": "tsx scripts/ingest-citations.ts",
    "ingest:vendor-pages": "tsx scripts/ingest-vendor-pages.ts",
    "cache:warm": "tsx scripts/warm-semantic-cache.ts",
    "dw:load": "tsx scripts/load-citation-warehouse.ts",
    "dw:ecosystem": "tsx scripts/load-ecosystem-catalog.ts",
    "dreams:consolidate": "tsx scripts/dreams-consolidate.ts",
    "verify:dw": "tsx scripts/verify-dw.ts",
    "service:refresh": "npm run crawl:vendors && npm run service:refresh:local",
    "service:refresh:local": "npm run ingest:citations && npm run cache:warm && npm run dw:load && npm run dreams:consolidate",
    "example:vend-citations": "tsx src/examples/vend-citations.ts",
    "eval:rubric": "tsx scripts/eval-citation-rubric.ts"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@anthropic-ai/claude-agent-sdk": "^0.3.178",
    "@anthropic-ai/sdk": "^0.104.2",
    "@crawlee/cheerio": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@msgpack/msgpack": "^3.0.0",
    "@openfeature/server-sdk": "^1.21.0",
    "@redis/bloom": "^6.0.0",
    "@redis/json": "^6.0.0",
    "@redis/search": "^6.0.0",
    "@redis/time-series": "^6.0.0",
    "@turbopuffer/turbopuffer": "^2.0.0",
    "@types/cheerio": "^0.22.35",
    "@types/express": "^5.0.6",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@xenova/transformers": "^2.17.2",
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "hono": "4.12.23",
    "lru-cache": "^11.0.0",
    "mdast-util-from-markdown": "^2.0.3",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "redis": "^6.0.0",
    "turndown": "^7.0.0",
    "unist-util-visit": "^5.1.0",
    "wink-bm25-text-search": "^3.1.2",
    "ws": "^8.20.1",
    "yaml": "^2.9.0",
    "zod": "^4.0.0"
  },
  "overrides": {
    "@anthropic-ai/sdk": "^0.104.2",
    "file-type": "^21.3.1",
    "protobufjs": "^7.5.6",
    "shell-quote": ">=1.8.4",
    "esbuild": ">=0.28.1"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.21.0",
    "@modelcontextprotocol/server-pdf": "^1.7.2",
    "@types/node": "^22.7.0",
    "@types/turndown": "^5.0.0",
    "c8": "^11.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "typescript-language-server": "^5.3.0",
    "vscode-langservers-extracted": "^4.10.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/subagentceo/knowledge-engineering.git"
  }
}
