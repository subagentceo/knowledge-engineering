{
  "name": "@subagentceo/knowledge-engineering",
  "version": "0.1.0",
  "description": "Claude Agent SDK node with sub-agents, MCP tools, and a tool-anchored knowledge graph derived from llms.txt sources.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ke-npm-mcp": "dist/mcp/npm-registry-server.js",
    "ke-agent": "dist/agent/run.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/agent/run.ts",
    "mcp:npm": "tsx src/mcp/npm-registry-server.ts",
    "example:anthropic": "tsx src/examples/anthropic-features.ts",
    "docs:dev": "mintlify dev",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@anthropic-ai/sdk": "^0.40.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/subagentceo/knowledge-engineering.git"
  }
}
