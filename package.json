{
  "name": "@subagentceo/knowledge-engineering",
  "version": "0.1.0",
  "description": "Four-lane knowledge bridge (anthropic.com/engineering, claude.com/blog, support.claude.com, llms.txt namespaces) exposed over MCP SDK v2 to a Claude Agent SDK orchestrator. OAuth-only.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ke-bridge-mcp": "dist/mcp/bridge-server.js",
    "ke-agent": "dist/agent/run.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/agent/run.ts",
    "mcp:bridge": "tsx src/mcp/bridge-server.ts",
    "docs:dev": "mintlify dev",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@modelcontextprotocol/sdk": "^2.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/subagentceo/knowledge-engineering.git"
  }
}
