{
  "$schema": "./secrets-parity.schema.json",
  "version": 1,
  "comment": "Canonical parity table for OSEC1. See docs/decisions/2026-05-17-secrets-parity.md. Planes: local, gh_repo, gh_org, cloud_env. Values: REQUIRED | OPTIONAL | FORBIDDEN | NA.",
  "secrets": [
    {
      "name": "ANTHROPIC_API_KEY",
      "local": "FORBIDDEN",
      "gh_repo": "FORBIDDEN",
      "gh_org": "FORBIDDEN",
      "cloud_env": "FORBIDDEN",
      "rationale": "OAuth-only invariant. src/oauth/token.ts fails closed when present."
    },
    {
      "name": "CLAUDE_CODE_OAUTH_TOKEN",
      "local": "REQUIRED",
      "gh_repo": "REQUIRED",
      "gh_org": "REQUIRED",
      "cloud_env": "REQUIRED",
      "rationale": "Replaces ANTHROPIC_API_KEY. Already at repo + org scope."
    },
    {
      "name": "CLOUDFLARE_ACCOUNT_ID",
      "local": "OPTIONAL",
      "gh_repo": "REQUIRED",
      "gh_org": "REQUIRED",
      "cloud_env": "REQUIRED",
      "rationale": "Worker deploy + Hyperdrive provisioning."
    },
    {
      "name": "CLOUDFLARE_API_TOKEN",
      "local": "OPTIONAL",
      "gh_repo": "REQUIRED",
      "gh_org": "REQUIRED",
      "cloud_env": "REQUIRED",
      "rationale": "Worker deploy."
    },
    {
      "name": "NEON_API_KEY",
      "local": "OPTIONAL",
      "gh_repo": "REQUIRED",
      "gh_org": "REQUIRED",
      "cloud_env": "REQUIRED",
      "rationale": "scripts/mint-neon-api-secret.ts + Neon branch workflow."
    },
    {
      "name": "TURBOPUFFER_API_KEY_WRITE",
      "local": "OPTIONAL",
      "gh_repo": "REQUIRED",
      "gh_org": "REQUIRED",
      "cloud_env": "REQUIRED",
      "rationale": "Platform-engineering bridge writes to turbopuffer."
    }
  ]
}
