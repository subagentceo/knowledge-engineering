{
  "$schema": "https://schemas.anthropic.com/cowork-coworkers.schema.json",
  "version": "0.2.0",
  "description": "Cowork multi-coworker manifest. Coworkers are protocol-native: they communicate via four peer protocols \u2014 a2a, acp, mcp, and e2m-mcp. Unlike simple 'agents', coworkers have peer relationships, shared context, and can initiate work \u2014 not just receive it.",
  "protocols": {
    "a2a": {
      "full": "agent-to-agent",
      "description": "Direct peer invocation \u2014 coworkers call each other by id without a broker."
    },
    "acp": {
      "full": "agent-client-protocol",
      "description": "HTTP REST \u2014 coworkers expose /run endpoints consumed by external clients."
    },
    "mcp": {
      "full": "model-context-protocol",
      "description": "Tool surfaces \u2014 coworkers expose typed MCP tools to models and other coworkers."
    },
    "e2m-mcp": {
      "full": "envelope-to-mailbox-mcp",
      "description": "JSONL durable queue \u2014 coworkers write/read typed DurableTask envelopes via cowork/mcp/e2m-mcp/server.ts. First-class peer protocol, not a transport wrapper.",
      "server": "cowork/mcp/e2m-mcp/server.ts"
    }
  },
  "session_model": {
    "mechanical": "claude-haiku-4-5-20251001",
    "review": "claude-sonnet-4-6",
    "planning": "claude-sonnet-4-6"
  },
