{
  "$schema": "https://schemas.anthropic.com/cowork-coworkers.schema.json",
  "version": "0.2.0",
  "description": "Cowork multi-coworker manifest. Coworkers are protocol-native: they communicate via four peer protocols — a2a, acp, mcp, and e2m-mcp. Unlike simple 'agents', coworkers have peer relationships, shared context, and can initiate work — not just receive it.",
  "protocols": {
    "a2a":     { "full": "agent-to-agent", "description": "Direct peer invocation — coworkers call each other by id without a broker." },
    "acp":     { "full": "agent-client-protocol", "description": "HTTP REST — coworkers expose /run endpoints consumed by external clients." },
    "mcp":     { "full": "model-context-protocol", "description": "Tool surfaces — coworkers expose typed MCP tools to models and other coworkers." },
    "e2m-mcp": { "full": "envelope-to-mailbox-mcp", "description": "JSONL durable queue — coworkers write/read typed DurableTask envelopes via cowork/mcp/e2m-mcp/server.ts. First-class peer protocol, not a transport wrapper.", "server": "cowork/mcp/e2m-mcp/server.ts" }
  },
  "session_model": {
    "mechanical": "claude-haiku-4-5-20251001",
    "review":     "claude-sonnet-4-6",
    "planning":   "claude-sonnet-4-6"
  },
  "coworkers": [
    {
      "id": "pm-coworker",
      "display_name": "Product Management",
      "domain": "product-management",
      "queue": "cowork/data/queues/product-management.jsonl",
      "mailbox": "cowork/data/mailbox/pm-coworker.jsonl",
      "skill": "cowork/coworkers/skills/pm-coworker/SKILL.md",
      "model": "claude-sonnet-4-6",
      "trigger_phrase": "/pm-coworker",
      "protocols": ["a2a", "e2m-mcp", "mcp"],
      "peers": ["design-coworker", "engineering-coworker", "data-coworker", "sales-coworker", "operations-coworker", "finance-coworker"],
      "description": "Lead PM. Routes work, manages priority-rerank cadence, maintains product-management queue. Orchestrates peer coworkers via e2m-mcp mailbox_send.",
      "subdomain_surface": "coworkers.subagentknowledge.com/product-management",
      "test": "cowork/coworkers/tests/pm-coworker.test.ts"
    },
    {
      "id": "design-coworker",
      "display_name": "Design",
      "domain": "design",
      "queue": "cowork/data/queues/design.jsonl",
      "mailbox": "cowork/data/mailbox/design-coworker.jsonl",
      "skill": "cowork/coworkers/skills/design-coworker/SKILL.md",
      "model": "claude-sonnet-4-6",
      "trigger_phrase": "/design-coworker",
      "protocols": ["a2a", "e2m-mcp"],
      "peers": ["pm-coworker", "engineering-coworker"],
      "description": "Design token + HTML artifact coworker. Owns cowork/artifacts/ and the 8-token design system.",
      "subdomain_surface": "coworkers.subagentknowledge.com/design",
      "test": "cowork/coworkers/tests/design-coworker.test.ts"
    },
    {
      "id": "engineering-coworker",
      "display_name": "Engineering",
      "domain": "engineering",
      "queue": "cowork/data/queues/engineering.jsonl",
      "mailbox": "cowork/data/mailbox/engineering-coworker.jsonl",
      "skill": "cowork/coworkers/skills/engineering-coworker/SKILL.md",
      "model": "claude-haiku-4-5-20251001",
      "trigger_phrase": "/engineering-coworker",
      "protocols": ["a2a", "e2m-mcp", "mcp"],
      "peers": ["pm-coworker", "data-coworker"],
      "description": "TypeScript + Rust implementation coworker. Owns cowork/mcp/, cowork/templates/, src/.",
      "subdomain_surface": "coworkers.subagentknowledge.com/engineering",
      "test": "cowork/coworkers/tests/engineering-coworker.test.ts"
    },
    {
      "id": "data-coworker",
      "display_name": "Data",
      "domain": "data",
      "queue": "cowork/data/queues/data.jsonl",
      "mailbox": "cowork/data/mailbox/data-coworker.jsonl",
      "skill": "cowork/coworkers/skills/data-coworker/SKILL.md",
      "model": "claude-haiku-4-5-20251001",
      "trigger_phrase": "/data-coworker",
      "protocols": ["a2a", "e2m-mcp"],
      "peers": ["pm-coworker", "engineering-coworker"],
      "description": "AlloyDB / Kimball DW coworker. Owns dw.* schema, dim_agent_templates, fact tables.",
      "subdomain_surface": "coworkers.subagentknowledge.com/data",
      "test": "cowork/coworkers/tests/data-coworker.test.ts"
    },
    {
      "id": "sales-coworker",
      "display_name": "Sales",
      "domain": "sales",
      "queue": "cowork/data/queues/sales.jsonl",
      "mailbox": "cowork/data/mailbox/sales-coworker.jsonl",
      "skill": "cowork/coworkers/skills/sales-coworker/SKILL.md",
      "model": "claude-haiku-4-5-20251001",
      "trigger_phrase": "/sales-coworker",
      "protocols": ["a2a", "e2m-mcp"],
      "peers": ["pm-coworker", "finance-coworker"],
      "description": "Outreach + mail coworker. Owns cowork/apps/mail/, sales queue, finance cost tracking.",
      "subdomain_surface": "coworkers.subagentknowledge.com/sales",
      "test": "cowork/coworkers/tests/sales-coworker.test.ts"
    },
    {
      "id": "operations-coworker",
      "display_name": "Operations",
      "domain": "operations",
      "queue": "cowork/data/queues/operations.jsonl",
      "mailbox": "cowork/data/mailbox/operations-coworker.jsonl",
      "skill": "cowork/coworkers/skills/operations-coworker/SKILL.md",
      "model": "claude-haiku-4-5-20251001",
      "trigger_phrase": "/operations-coworker",
      "protocols": ["a2a", "e2m-mcp", "acp"],
      "peers": ["pm-coworker", "finance-coworker", "engineering-coworker"],
      "description": "Infrastructure + process coworker. Manages Cloudflare Workers, scheduled tasks, deploy pipelines, subdomain provisioning.",
      "subdomain_surface": "coworkers.subagentknowledge.com/operations",
      "test": "cowork/coworkers/tests/operations-coworker.test.ts"
    },
    {
      "id": "finance-coworker",
      "display_name": "Finance",
      "domain": "finance",
      "queue": "cowork/data/queues/finance.jsonl",
      "mailbox": "cowork/data/mailbox/finance-coworker.jsonl",
      "skill": "cowork/coworkers/skills/finance-coworker/SKILL.md",
      "model": "claude-haiku-4-5-20251001",
      "trigger_phrase": "/finance-coworker",
      "protocols": ["a2a", "e2m-mcp"],
      "peers": ["pm-coworker", "sales-coworker", "operations-coworker"],
      "description": "Cost tracking + vendor spend coworker. Owns finance.jsonl, cost approval gates, third-party spend tracking.",
      "subdomain_surface": "coworkers.subagentknowledge.com/finance",
      "test": "cowork/coworkers/tests/finance-coworker.test.ts"
    }
  ],
  "plugins": {
    "enterprise-search": {
      "skills": ["digest", "knowledge-synthesis", "search", "search-strategy", "source-management"],
      "coworker_affinity": ["pm-coworker", "data-coworker", "engineering-coworker"],
      "description": "Cross-vendor doc search across 25 vendor surfaces in vendor/. Powers the enterprise knowledge surface."
    },
    "productivity": {
      "skills": ["memory-management", "start", "task-management", "update"],
      "coworker_affinity": ["pm-coworker"],
      "description": "Session continuity, heartbeat, task routing. Extends structured-prompt-resume."
    },
    "skill-ci-cd": {
      "skills": ["durable-agent-ci-cd-rubrics", "durable-agent-ci-cd-evals", "durable-agent-ci-cd-outcomes"],
      "skill_paths": [
        ".claude/skills/durable-agent-ci-cd-rubrics/SKILL.md",
        ".claude/skills/durable-agent-ci-cd-evals/SKILL.md",
        ".claude/skills/durable-agent-ci-cd-outcomes/SKILL.md"
      ],
      "coworker_affinity": ["engineering-coworker", "pm-coworker"],
      "description": "Merge gate for .claude/skills/. rubrics defines scoring (D1 type-safety, D2 durability, D3 agent-reuse, D4 packaging). evals runs the harness and writes cowork/data/queues/skill-grades.jsonl. outcomes reads grades, emits verdict per skill, and writes blocking DurableTasks to engineering.jsonl.",
      "protocols": ["e2m-mcp"],
      "cite": [
        ".claude/skills/durable-agent-ci-cd-rubrics/SKILL.md",
        "cowork/templates/task-state-machine.ts",
        "cowork/mcp/e2m-mcp/server.ts",
        "cowork/data/queues/skill-grades.jsonl",
        "cowork/data/queues/skill-outcomes.jsonl"
      ]
    },
    "durable-memory": {
      "skills": ["durable-lru-dreams", "durable-pg-memory-store"],
      "skill_paths": [
        ".claude/skills/durable-lru-dreams/SKILL.md",
        ".claude/skills/durable-pg-memory-store/SKILL.md"
      ],
      "coworker_affinity": ["pm-coworker", "engineering-coworker", "data-coworker"],
      "description": "Redis LRU + postgres durable memory layer. durable-lru-dreams owns the Dreams API lifecycle and dream_consolidation task pipeline. durable-pg-memory-store owns memory store CRUD, memory version history, PII redact, and cache hit/miss telemetry. Both write DurableTask envelopes to engineering.jsonl via e2m-mcp.",
      "protocols": ["e2m-mcp"],
      "cite": [
        "platform.claude.com/docs/en/managed-agents/dreams.md",
        "platform.claude.com/docs/en/managed-agents/memory.md",
        "cowork/templates/task-state-machine.ts",
        ".claude/skills/durable-lru-dreams/references/durable-dreams-memory-tasks.sql"
      ]
    }
  },
  "continuity": {
    "queue_dir":   "cowork/data/queues",
    "mailbox_dir": "cowork/data/mailbox",
    "resume_skill": "cowork/skills/user/structured-prompt-resume/SKILL.md",
    "test_runner": "cowork/coworkers/tests/run-all.ts",
    "session_break_protocol": "read mailbox → read queue → claim highest_priority pending → execute → write transition"
  },
  "cite": [
    "cowork/mcp/e2m-mcp/server.ts",
    "cowork/templates/task-state-machine.ts",
    "cowork/skills/plugins/product-management:priority-rerank/SKILL.md",
    "seeds/posture/session-start.xml"
  ]
}
