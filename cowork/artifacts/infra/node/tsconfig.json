{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "..",
    "baseUrl": ".",
    "paths": {
      "pg": ["node_modules/@types/pg"],
      "pg-pool": ["node_modules/@types/pg-pool"],
      "debug": ["node_modules/debug"],
      "*": ["node_modules/*", "node_modules/@types/*"]
    },
    "typeRoots": [
      "./node_modules/@types",
      "../node_modules/@types"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true
  },
  "include": ["../**/*.ts"],
  "exclude": ["../node_modules", "dist"]
}
