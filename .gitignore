node_modules/
dist/
.env
.env.local
# .env.defaults is NON-SECRET and intentionally committed (loaded by
# scripts/load_project_env.sh). Keep it tracked even if .env* is broadened later.
!.env.defaults
*.log
.DS_Store
.mintlify/

# Cloudflare Worker / Sandbox local-dev artifacts
.wrangler/
infra/cloudflare/.dev.vars
infra/cloudflare/node_modules/

# Crawlee persistent storage (we set storageDir explicitly into node_modules/.crawlee-storage)
node_modules/.crawlee-storage/
coverage/

# OHYG1: third_party/ is operator-side read-only upstream mirror (workerd,
# workers-sdk, terragrunt, etc.). Never tracked, never scanned. The verify chain,
# citation guard, and OSV-Scanner rely on these paths NOT being in git so they
# don't traverse 13k+ upstream files per PR run. See osv-scanner.toml for the
# defensive scan-side exclude (belt-and-suspenders).
third_party/

# Claude Code local session settings — operator-side, may contain secrets per
# global feedback memory. Never commit.
.claude/settings.local.json

# Claude Code scheduled-tasks runtime lock — per-session pid/sessionId state.
# Was tracked once in error (cd663ef #161); untracked in OLOCK1. Never commit.
.claude/scheduled_tasks.lock

# Agent isolation worktrees — runtime git worktrees created by Agent(isolation:"worktree").
# Ephemeral; never tracked. Branches pushed separately via PR flow.
.claude/worktrees/

# Local claude-in-chrome / scratch output — never deliverables, never committed.
screenshots/
webpages/
