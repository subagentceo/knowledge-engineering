    <connector name="turbopuffer"  status="bootstrapped-2026-05-15" commit="2335179"/>
    <connector name="parallel.ai"  status="skeleton-2026-05-15"     pr="#129"/>
    <connector name="nimbleway"    status="skeleton-2026-05-15"     pr="#130"/>
    <connector name="ollama"       status="skeleton-2026-05-15"     pr="#131"/>
  </connectors>

