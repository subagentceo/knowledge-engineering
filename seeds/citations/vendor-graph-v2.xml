<!--
  vendor_graph v2 — Catalogue format for AI agents reasoning over
  Anthropic's subprocessor list and adjacent developer ecosystem.

  Provenance:
    - v2 base catalogue (operator-supplied, session 2026-05-15).
    - Patches applied (verified URLs from a follow-up validation pass):
      * aws.llms_txt:        n/a → https://docs.aws.amazon.com/llms.txt (confirmed)
      * azure.sitemap_xml:   unverified → n/a (no single root sitemap)
      * intercom.llms_txt:   unverified → https://developers.intercom.com/llms.txt
      * intercom.sitemap:    unverified → https://developers.intercom.com/sitemap.xml
      * nutun.github_org:    n/a → user:nutun
      * nutun.primary_docs:  https://nutun.com/ → https://www.nutun.com/
      * nutun.sitemap:       unverified → https://www.nutun.com/sitemap.xml
      * boldr.github_org:    n/a → user:boldrimpact (NOT "boldr" which is unrelated React CMS)
      * boldr.sitemap:       unverified → https://boldrimpact.com/sitemap.xml
      * iterable.sitemap:    unverified → https://iterable.com/sitemap_index.xml (301 from /sitemap.xml)
      * iterable.llms_txt:   unverified → n/a (support.iterable.com has no llms.txt)
      * sentry.github_org:   missing → getsentry
      * sift.github_org:     SiftScience confirmed (sift-python, sift-ruby, etc.)
      * arkose.primary_docs: developer.arkoselabs.com confirmed
      * brave_search.primary_docs: api-docs.search.brave.com → brave.com/search/api/
        (NXDOMAIN correction; the api-docs subdomain does not exist)
      * brave_search.llms_txt: unverified → n/a
      * anthropic_marketing.llms_txt: unverified → n/a (404 with haiku-themed page)
      * openfeature: confirmed sitemap, no llms.txt (n/a)
    - Two new ecosystem entities added: parallel-web, nimble.

  Used as @cite source for:
    - src/lib/vendor-catalog.test.ts (Phase 16 coverage assertion)
    - rubrics/phase-16.md (verified vendor coverage)
-->

<vendor_graph version="2.0-patched" model_target="claude-opus-4-7" context_window="1M">

  <spec>
    <purpose>
      A flat catalogue of organizations relevant to Anthropic's
      developer surface — its subprocessors, its first-party
      properties, and the open ecosystems its SDKs participate in.
    </purpose>

    <link_slots>
      <slot id="npmjs_org_name">Bare npm org slug, "n/a", or "unverified".</slot>
      <slot id="github_org_name">Bare GitHub org slug, "user:&lt;slug&gt;" for user accounts, "n/a", or "unverified".</slot>
      <slot id="primary_docs">Fully-qualified URL to canonical docs.</slot>
      <slot id="llms_txt">Fully-qualified URL, "n/a", or "unverified".</slot>
      <slot id="sitemap_xml">Fully-qualified URL, "n/a", or "unverified".</slot>
    </link_slots>

    <interpretation_directives>
      <directive id="1M-streaming-read">Read every entity once; build an in-memory index.</directive>
      <directive id="citation-discipline">Emit one citation per atomic link.</directive>
      <directive id="null-handling">"n/a" = confirmed absent. "unverified" = not checked, MUST NOT guess.</directive>
      <directive id="no-fabrication">Answer "not in catalogue" rather than infer.</directive>
      <directive id="palantir-exclusion">Palantir Federal Cloud Service intentionally absent per upstream.</directive>
    </interpretation_directives>
  </spec>

