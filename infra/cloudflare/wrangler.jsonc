// infra/cloudflare/wrangler.jsonc
//
// Phase 0g scaffold. Per the cited Neon guide:
//   vendor/anthropics/neon.com/guides/cloudflare-sandbox-neon-branching.md
//
// OAuth substitution: the cited guide pipes ANTHROPIC_API_KEY into the
// sandbox; we forward CLAUDE_CODE_OAUTH_TOKEN instead. ANTHROPIC_API_KEY is
// neither bound here nor forwarded into a sandbox at runtime (see the
// env-sanitizer in src/worker.ts).
//
// Not deployed in this PR. `wrangler deploy --dry-run` should validate;
// `wrangler deploy` is gated on Phase 8 + operator-side secret sync.
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ke-cloud-agent",
  "main": "src/worker.ts",
  "compatibility_date": "2026-01-01",
  "compatibility_flags": ["nodejs_compat"],

  // Containers (Cloudflare Sandboxes run as Durable Object containers).
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "max_instances": 50
    }
  ],

  "durable_objects": {
    "bindings": [
      {
        "name": "Sandbox",
        "class_name": "Sandbox"
      }
    ]
  },

  "migrations": [
    {
      "new_sqlite_classes": ["Sandbox"],
      "tag": "v1"
    }
  ],

  // Secrets via Cloudflare Secrets Store (account-level, bound here).
  // Cited from:
  //   https://developers.cloudflare.com/secrets-store/integrations/workers/
  //   https://developers.cloudflare.com/secrets-store/manage-secrets/how-to/
  //
  // The store + secrets are bootstrapped autonomously by the
  // cloudflare-preview.yml CI workflow on first deploy (idempotent
  // `wrangler secrets-store store/secret create --remote`). The only
  // required operator action is provisioning a `CLOUDFLARE_API_TOKEN`
  // GH repo secret with `Secrets Store Write` permission — that's the
  // irreducible minimum because no Cloudflare MCP tool exposes
  // secret_store creation, and no token can be minted autonomously.
  //
  // store_id is intentionally a placeholder; the bootstrap workflow
  // resolves it via `wrangler secrets-store store list --output json`
  // and patches this file in-place if needed (or the operator can
  // pin it directly).
  //
  // ANTHROPIC_API_KEY is NOT bound. The env-sanitizer in
  // src/worker.ts rejects any forwarded env containing that key —
  // independent layer-2 defense even if a misconfiguration ever
  // attempts to bind it.
  "secrets_store_secrets": [
    {
      "binding": "CLAUDE_CODE_OAUTH_TOKEN",
      "store_id": "565244614fc34be7aa8488ce46112f60",
      "secret_name": "CLAUDE_CODE_OAUTH_TOKEN"
    },
    {
      "binding": "NEON_API_KEY",
      "store_id": "565244614fc34be7aa8488ce46112f60",
      "secret_name": "NEON_API_KEY"
    },
    {
      "binding": "GITHUB_TOKEN",
      "store_id": "565244614fc34be7aa8488ce46112f60",
      "secret_name": "GITHUB_TOKEN"
    }
  ],

  "vars": {
    "IS_SANDBOX": "0",
    // Project ID is non-secret and matches the GH var of the same name.
    "NEON_PROJECT_ID": "divine-cloud-27295848"
  },

  // Phase 13.B+ (O5). Cloudflare Flagship binding — DEFERRED until the
  // operator (or an agent with `flagship:write` OAuth scope) creates the
  // Flagship app and pins its real app_id.
  //
  // History:
  //   - Phase 0g: binding declared with FLAGSHIP_APP_ID_PLACEHOLDER. The
  //     wrangler.jsonc comment noted production deploy would fail until
  //     the operator pinned a real id — empirically confirmed 2026-05-15:
  //     `wrangler deploy` returned code 10364 "Flagship app
  //     'FLAGSHIP_APP_ID_PLACEHOLDER' not found".
  //   - Phase 8 (2026-05-15): block commented out so Phase 8 C4 deploy
  //     can land without the operator-side Flagship runbook. The Worker's
  //     `resolveFlagshipString()` returns the supplied defaults whenever
  //     `env.FLAGSHIP` is undefined, which it now is.
  //
  // To re-enable Flagship: provision app at dash.cloudflare.com/flagship,
  // uncomment the block below, paste the real app_id, redeploy. The
  // operator's local wrangler OAuth token lacks `flagship:write` scope
  // (refresh with `wrangler login --scopes flagship:write,...`).
  //
  // "flagship": [
  //   {
  //     "binding": "FLAGSHIP",
  //     "app_id": "<real-app-id-from-dash>"
  //   }
  // ]
}
